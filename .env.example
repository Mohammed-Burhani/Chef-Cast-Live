# ChefCast: Live - Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat Configuration (for subscriptions)
# Get these from RevenueCat dashboard: https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-ios-key-here
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-android-key-here

# Mixpanel Configuration (for analytics)
# Get this from Mixpanel project settings: https://mixpanel.com
EXPO_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token-here

# Sentry Configuration (for error tracking)
# Get this from Sentry project settings: https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Expo Push Notifications
# These are automatically configured by Expo
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# Development Settings
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_ENABLE_DEV_TOOLS=true
